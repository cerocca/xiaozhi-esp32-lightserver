# Root Docker Compose settings for first boot.
# Copy this file to .env and adjust only what you need.

# Public host or LAN IP that devices and browsers should use.
# Docker Compose does not consume this directly yet; copy the same value into
# data/.config.yaml for server.websocket and server.vision_explain.
SERVER_HOST=127.0.0.1

# Published host ports for Docker Compose.
# Leave these at the defaults unless you intentionally want different host ports.
WS_PORT=8000
HTTP_PORT=8003

# Container timezone.
TZ=UTC

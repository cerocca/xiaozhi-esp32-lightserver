# Required for first start
# When running from ./admin-ui inside the monorepo:
# - XIAOZHI_DIR points to the monorepo root (docker compose location)
# - XIAOZHI_CONFIG points to the shared backend config under ../data
ADMIN_UI_HOST=0.0.0.0
ADMIN_UI_PORT=8088
BACKEND_HOST=127.0.0.1
BACKEND_HEALTH_PORT=8003
XIAOZHI_DIR=..
XIAOZHI_CONFIG=../data/.config.yaml
PIPER_SERVICE_NAME=piper-api

# Optional overrides
# Standalone installs can override XIAOZHI_DIR and XIAOZHI_CONFIG to match their local layout.
# Relative paths are resolved from the admin-ui directory.
# XSERVER_SCRIPT_PATH=scripts/xserver.sh
# PIPER_SCRIPT_PATH=scripts/piper.sh
# XSERVER_SERVICE_NAME=xiaozhi-server
# PIPER_HEALTH_URL=http://127.0.0.1:8091/health
# LAN_CIDR=192.168.1.0/24
